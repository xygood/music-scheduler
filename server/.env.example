# 后端环境变量配置示例
# 复制此文件为 .env 并修改配置

# 环境模式
FLASK_ENV=production

# 密钥（必须修改！）
SECRET_KEY=your-secret-key-here-change-this-in-production

# 数据库配置
# SQLite（开发/小型部署）
DATABASE_URL=sqlite:///music_scheduler.db

# PostgreSQL（生产环境推荐）
# DATABASE_URL=postgresql://username:password@localhost:5432/music_scheduler

# 服务器配置
HOST=127.0.0.1
PORT=5000

# CORS配置（允许的前端域名）
CORS_ORIGINS=https://your-domain.com,http://localhost:5173

# 日志级别
LOG_LEVEL=INFO
